# Environment Variables Template for Ferry Integration
# Copy this to .env and fill in your actual values

# Barentswatch API Credentials
# Get these from https://www.barentswatch.no/ developer portal
BARENTSWATCH_CLIENT_ID=your-barentswatch-client-id-here
BARENTSWATCH_CLIENT_SECRET=your-barentswatch-client-secret-here

# For Railway deployment, use these commands instead:
# railway variables set BARENTSWATCH_CLIENT_ID="your-client-id"
# railway variables set BARENTSWATCH_CLIENT_SECRET="your-client-secret"